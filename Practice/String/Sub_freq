public class Curtains {

    public static void main(String[] args) {
        String str = "bbbaaababa";
        int n = 3;

        maxLength1(str, n);
        maxLength2(str, n);

    }

    static void maxLength1(String str, int n){

        int c = 0;
        for(int i = 0; i < n;i++){
          if(str.charAt(i) == 'a'){
            c++;
          }
        }
        int maxA =  c;

        for(int j = n; j< str.length();j++){
          if(str.charAt(j - n) == 'a'){
            c--;
          }

          if(str.charAt(j) == 'a'){
            c++;
          }
          maxA = Math.max(maxA, c);
        }

        System.out.println(maxA);
    }

    static void maxLength2(String str, int n){

        int maxA = 0;

        for(int i=0;i<str.length();i+=n){

          int c = 0;

          int end = Math.min(i+n, str.length());

          for(int j = i; j < end;j++){

            if(str.charAt(j) == 'a'){
              c++;
            }
          }
          maxA = Math.max(maxA, c);
        }
        System.out.println(maxA);
    }
}
